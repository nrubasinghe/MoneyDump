# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# --- OpenAI ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Database ---
# Leave blank to use the default SQLite file (budget.db) next to this folder
DATABASE_URL=

# --- RAG Paths (leave blank to use defaults relative to the API folder) ---
KNOWLEDGE_BASE_PATH=
VECTOR_DB_PATH=

# --- JWT / Security ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Demo Seed User (only used by seed.py / refresh_demo_data.py) ---
DEMO_EMAIL=user@example.com
DEMO_PASSWORD=password123
